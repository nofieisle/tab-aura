{
  "manifest_version": 3,
  "name": "Tab Aura",
  "version": "1.1.0",
  "description": "アクティブタブのタイトルに🟥バッジを表示します",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
